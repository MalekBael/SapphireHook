#include "GameDataLookup.h"
#include <nlohmann/json.hpp>
#include <fstream>
#include <unordered_map>
#include <mutex>
#include <format>
#include "../Logger/Logger.h"

using SapphireHook::LogInfo;
using SapphireHook::LogWarning;

namespace GameData {

// ============================================================================
// Internal Storage
// ============================================================================

namespace {
    std::filesystem::path s_dataDir;
    LoadStats s_stats;
    std::mutex s_mutex;
    
    // Storage maps - key is ID, value is name string
    // We store std::string and return const char* for API compatibility
    std::unordered_map<uint32_t, std::string> s_items;
    std::unordered_map<uint32_t, std::string> s_actions;
    std::unordered_map<uint32_t, std::string> s_statuses;
    std::unordered_map<uint32_t, std::string> s_territories;
    std::unordered_map<uint8_t, std::string> s_classJobs;
    std::unordered_map<uint32_t, std::string> s_mounts;
    std::unordered_map<uint32_t, std::string> s_minions;
    std::unordered_map<uint32_t, std::string> s_emotes;
    std::unordered_map<uint32_t, std::string> s_quests;
    std::unordered_map<uint32_t, std::string> s_bnpcs;
    std::unordered_map<uint32_t, std::string> s_enpcs;
    
    // Helper to load a simple id->name JSON file
    // Expected format: { "123": "Name", "456": "Other Name" } or [{"id": 123, "name": "Name"}, ...]
    template<typename KeyT, typename MapT>
    bool LoadJsonMap(const std::filesystem::path& filepath, MapT& outMap, size_t& outCount) {
        try {
            if (!std::filesystem::exists(filepath)) {
                return false;
            }
            
            std::ifstream file(filepath);
            if (!file.is_open()) {
                LogWarning("[GameData] Failed to open: " + filepath.string());
                return false;
            }
            
            nlohmann::json j;
            file >> j;
            outMap.clear();
            
            if (j.is_object()) {
                // Format: { "123": "Name", ... }
                for (auto& [key, val] : j.items()) {
                    if (val.is_string()) {
                        KeyT id;
                        if constexpr (std::is_same_v<KeyT, uint8_t>) {
                            id = static_cast<KeyT>(std::stoul(key));
                        } else {
                            id = static_cast<KeyT>(std::stoul(key));
                        }
                        outMap[id] = val.get<std::string>();
                    }
                }
            } else if (j.is_array()) {
                // Format: [{"id": 123, "name": "Name"}, ...]
                for (auto& item : j) {
                    if (item.contains("id") && item.contains("name")) {
                        KeyT id = item["id"].get<KeyT>();
                        outMap[id] = item["name"].get<std::string>();
                    }
                }
            }
            
            outCount = outMap.size();
            LogInfo("[GameData] Loaded " + std::to_string(outCount) + " entries from " + filepath.filename().string());
            return true;
        }
        catch (const std::exception& e) {
            LogWarning("[GameData] Error loading " + filepath.string() + ": " + e.what());
            return false;
        }
    }
    
} // anonymous namespace

// ============================================================================
// Initialization
// ============================================================================

bool Initialize(const std::filesystem::path& dataDir) {
    std::lock_guard lock(s_mutex);
    
    s_dataDir = dataDir;
    s_stats = LoadStats{};
    
    if (!std::filesystem::exists(dataDir)) {
        LogInfo("[GameData] Data directory does not exist: " + dataDir.string());
        LogInfo("[GameData] Create JSON files (items.json, actions.json, etc.) to enable lookups");
        s_stats.initialized = true;
        return false;
    }
    
    LogInfo("[GameData] Loading from: " + dataDir.string());
    
    bool anyLoaded = false;
    
    // Load each data type
    anyLoaded |= LoadJsonMap<uint32_t>(dataDir / "items.json", s_items, s_stats.itemCount);
    anyLoaded |= LoadJsonMap<uint32_t>(dataDir / "actions.json", s_actions, s_stats.actionCount);
    anyLoaded |= LoadJsonMap<uint32_t>(dataDir / "statuses.json", s_statuses, s_stats.statusCount);
    anyLoaded |= LoadJsonMap<uint32_t>(dataDir / "territories.json", s_territories, s_stats.territoryCount);
    anyLoaded |= LoadJsonMap<uint8_t>(dataDir / "classjobs.json", s_classJobs, s_stats.classJobCount);
    anyLoaded |= LoadJsonMap<uint32_t>(dataDir / "mounts.json", s_mounts, s_stats.mountCount);
    anyLoaded |= LoadJsonMap<uint32_t>(dataDir / "minions.json", s_minions, s_stats.minionCount);
    anyLoaded |= LoadJsonMap<uint32_t>(dataDir / "emotes.json", s_emotes, s_stats.emoteCount);
    anyLoaded |= LoadJsonMap<uint32_t>(dataDir / "quests.json", s_quests, s_stats.questCount);
    anyLoaded |= LoadJsonMap<uint32_t>(dataDir / "bnpcs.json", s_bnpcs, s_stats.bnpcCount);
    anyLoaded |= LoadJsonMap<uint32_t>(dataDir / "enpcs.json", s_enpcs, s_stats.enpcCount);
    
    s_stats.initialized = true;
    
    if (!anyLoaded) {
        LogInfo("[GameData] No data files found. Expected files:");
        LogInfo("  - items.json     (item ID -> name)");
        LogInfo("  - actions.json   (action ID -> name)");
        LogInfo("  - statuses.json  (status effect ID -> name)");
        LogInfo("  - territories.json (zone ID -> name)");
        LogInfo("  - classjobs.json (class/job ID -> name)");
        LogInfo("  - mounts.json    (mount ID -> name)");
        LogInfo("  - minions.json   (minion ID -> name)");
        LogInfo("  - emotes.json    (emote ID -> name)");
        LogInfo("  - quests.json    (quest ID -> name)");
        LogInfo("  - bnpcs.json     (battle NPC name ID -> name)");
        LogInfo("  - enpcs.json     (event NPC ID -> name)");
    }
    
    return anyLoaded;
}

bool Reload() {
    if (s_dataDir.empty()) return false;
    return Initialize(s_dataDir);
}

const std::filesystem::path& GetDataDirectory() {
    return s_dataDir;
}

// ============================================================================
// Lookup Functions
// ============================================================================

const char* LookupItemName(uint32_t itemId) noexcept {
    auto it = s_items.find(itemId);
    return (it != s_items.end()) ? it->second.c_str() : nullptr;
}

std::string FormatItem(uint32_t itemId) {
    if (auto* name = LookupItemName(itemId)) {
        return std::format("{} ({})", name, itemId);
    }
    return std::to_string(itemId);
}

const char* LookupActionName(uint32_t actionId) noexcept {
    auto it = s_actions.find(actionId);
    return (it != s_actions.end()) ? it->second.c_str() : nullptr;
