{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Generate Doxygen (HTML)",
      // CHANGE NOTE (2025-12-15): Switched to a process task to avoid VS Code shell
      // quoting issues with nested PowerShell -Command strings.
      "type": "process",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-Command",
        "$ErrorActionPreference='Stop'; Set-Location '${workspaceFolder}'; $doxygen=(Get-Command doxygen -ErrorAction SilentlyContinue).Source; if (-not $doxygen) { $candidate = Join-Path $env:ProgramFiles 'doxygen\\bin\\doxygen.exe'; if (Test-Path $candidate) { $doxygen = $candidate } }; if ($doxygen) { & $doxygen 'Doxyfile' } else { Write-Host 'Doxygen not found; skipping (install: winget install DimitriVanHeesch.Doxygen)'; exit 0 }"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "Build SapphireHook DLL (MSBuild)",
      "type": "process",
      "command": "K:/Program Files/Microsoft Visual Studio/18/Insiders/MSBuild/Current/Bin/MSBuild.exe",
      "args": [
        "SapphireHookDLL.vcxproj",
        "/t:Build",
        "/p:Configuration=Debug",
        "/p:Platform=x64"
      ],
      "problemMatcher": ["$msCompile"]
    },
    {
      "label": "Build Injector EXE (MSBuild)",
      "type": "process",
      "command": "K:/Program Files/Microsoft Visual Studio/18/Insiders/MSBuild/Current/Bin/MSBuild.exe",
      "args": [
        "SapphireHookInjector/SapphireHookInjector.vcxproj",
        "/t:Build",
        "/p:Configuration=Debug",
        "/p:Platform=x64"
      ],
      "problemMatcher": ["$msCompile"]
    },
    {
      "label": "Build All (MSBuild)",
      "dependsOn": [
        "Build SapphireHook DLL (MSBuild)",
        "Build Injector EXE (MSBuild)",
        "Generate Doxygen (HTML)"
      ],
      "dependsOrder": "sequence",
      "type": "process",
      "command": "K:/Program Files/Microsoft Visual Studio/18/Insiders/MSBuild/Current/Bin/MSBuild.exe",
      "args": [
        "SapphireHookDLL.vcxproj",
        "/t:Build",
        "/p:Configuration=Debug",
        "/p:Platform=x64"
      ],
      "problemMatcher": ["$msCompile"],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    }
  ]
}